# Copy this file to `config.toml` (at project root) to override tuning defaults.
# Any section/key you omit falls through to the dataclass default in code.
# The real `config.toml` is gitignored so your local tuning stays private.

[gamepad.ai_aim]
# Legacy smoothing value still applies when explicit legacy sub-plugins are used.
# Default 0.62.
smoothing = 0.62
# Pixel error mapped to full-scale stick deflection. Default 130.
max_pixels = 130
# Global multiplier applied to target_dx/dy before snap/body-lock mapping.
# Default 0.7.
ai_delta_gain = 0.7
# First-ADS snap window in milliseconds. Default 100.
ads_snap_window_ms = 100
# Snap can be aggressive in v1, so the default smoothing is 0.0.
ads_snap_smoothing = 0.0
ads_snap_max_ai_force = 1.0
ads_snap_max_ai_force_y = 1.0
# Body Lock only engages after the crosshair is already inside the body box
# (plus tolerance) and the upper-body lock point stays inside a central box.
body_lock_activation_box_px = 150.0
body_lock_box_tolerance_px = 18.0
body_lock_smoothing = 0.18
body_lock_max_ai_force = 0.42
body_lock_max_ai_force_y = 0.48
# Frames of stable target continuity needed before body-lock suppression gets aggressive.
body_lock_confidence_frames = 4
# Confidence threshold above which opposing manual input is strongly cut down.
body_lock_confidence_min_strong = 0.65
# Maximum fraction of harmful manual input that can be removed while lock confidence is high.
body_lock_opposing_suppression_max = 0.9
# Maximum damping applied to orthogonal wobble near the lock point.
body_lock_orthogonal_suppression_max = 0.75
# Minimum fraction of aligned manual input that still survives arbitration.
body_lock_helpful_preservation_floor = 0.8
# Near-lock radius where orthogonal damping ramps up.
body_lock_near_lock_error_px = 18.0
# Slight extra damping on vertical orthogonal wobble around the upper-body point.
body_lock_vertical_orthogonal_bias = 1.15
# Suppress tiny vertical twitch near the upper-body lock point.
body_lock_vertical_deadzone_px = 6.0
# When target motion slows down, gradually restore some Y tail help from
# this inner threshold up to the deadzone edge instead of hard-zeroing.
body_lock_vertical_tail_inner_px = 2.0
body_lock_vertical_tail_speed_threshold_px_per_sec = 90.0
body_lock_upper_body_ratio = 0.38
# Optional movement compensation once the same target has been tracked for
# several frames.
body_lock_lead_frames = 4
body_lock_lead_seconds = 0.05
# Keep vertical prediction a bit softer than horizontal to reduce lock twitch.
body_lock_vertical_lead_scale = 0.95
body_lock_lead_max_px = 18.0

[gamepad.adaptive_delta_gain]
# Short-term bonus kicks in when error fails to shrink for N consecutive
# observations. Per-axis, capped at max_bonus.
min_error_px = 6.0
trigger_frames = 3
gain_per_update = 0.08
decay_per_update = 0.12
max_bonus = 0.6
opposing_input_threshold = 4500
stale_seconds = 0.15

[mouse.ai_aim]
# Per-frame correction gain. Default 0.06.
gain = 0.06
smoothing = 0.65
# Hard cap on AI correction per frame (pixels). Default 1.5.
max_correction_px = 1.5
# Fraction of manual mouse movement to counteract when a target is present.
# Default 0.4.
manual_dampen = 0.4
